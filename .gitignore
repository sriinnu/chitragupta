# Dependencies
node_modules/

# Build
dist/
*.tsbuildinfo

# Environment & Secrets
.env
.env.*
!.env.example
*.pem
*.key
credentials.json

# Runtime state & databases
.chitragupta/
.tmp/
sessions/
consolidation/
*.db
*.db-wal
*.db-shm
mcp-state.json

# Claude Code local config
.claude/

# Codex local config
.codex/

# Local machine-specific config
.mcp.json
settings.local.json

# Compiled output in src/ (should only be in dist/)
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
!packages/*/src/types.d.ts
packages/*/src/**/*.d.ts.map

# Logs
*.log

# Coverage
coverage/

# Lock files (pnpm is canonical)
package-lock.json

# Work-in-progress docs (local only — not pushed)
work-in-progress/

# Audit/review/health reports (local only)
HEALTH.md
*-AUDIT.md
REVIEW-*.md
docs/REVIEW-*.md
TASK.md
TASK-COMPLETE*.md

# Backup files
*.bak

# Scratch / generation scripts
_data.json
_gen.mjs
_write_tests.py

# Xcode (generated by XcodeGen — do not commit)
*.xcodeproj
*.xcworkspace
xcuserdata/
DerivedData/

# OS
.DS_Store
Thumbs.db

# Agent working directories
.agents/

# Session task/completion reports (ephemeral)
TASK.md
TASK-COMPLETE*.md
**/TASK-COMPLETE*.md
**/REFACTOR_COMPLETE.md
**/*-AUDIT.md

# Internal audit/health reports (local only — never publish)
HEALTH.md

# Git worktrees (local lane branches)
.worktrees/

# pnpm build approvals (machine-specific)
.pnpm-approved-builds.json

# Legacy
.lodestar

