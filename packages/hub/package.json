    "./signals/budget": "./src/signals/budget.ts",
    "./signals/cognitive": "./src/signals/cognitive.ts",
    "./signals/realtime": "./src/signals/realtime.ts"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
