{
	"name": "@chitragupta/daemon",
	"version": "0.1.5",
	"description": "Centralized daemon — one process per user, Unix domain socket, JSON-RPC 2.0, single-writer SQLite, health monitoring, and auto-recovery",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/sriinnu/chitragupta.git",
		"directory": "packages/daemon"
	},
	"homepage": "https://github.com/sriinnu/chitragupta/tree/main/packages/daemon#readme",
	"bugs": {
		"url": "https://github.com/sriinnu/chitragupta/issues"
	},
	"keywords": [
		"chitragupta",
		"daemon",
		"socket",
		"rpc",
		"memory",
		"unix-socket",
		"json-rpc",
		"single-writer",
		"health-monitor",
		"circuit-breaker"
	],
	"exports": {
		".": "./dist/index.js",
		"./client": "./dist/client.js",
		"./resilience": "./dist/resilience.js",
		"./paths": "./dist/paths.js",
		"./process": "./dist/process.js"
	},
	"bin": {
		"chitragupta-daemon": "./dist/entry.js"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsc",
		"test": "sh -lc 'cd ../.. && pnpm exec vitest run --config vitest.config.ts packages/daemon/test/*.test.ts'"
	},
	"dependencies": {
		"@chitragupta/core": "workspace:*",
		"@chitragupta/dharma": "workspace:*",
		"@chitragupta/smriti": "workspace:*",
		"@chitragupta/anina": "workspace:*",
		"@chitragupta/sutra": "workspace:*",
		"@chitragupta/tantra": "workspace:*",
		"kosha-discovery": "^0.3.1"
	},
	"devDependencies": {
		"typescript": "^5.6.0"
	}
}
